% Korean:
% 포스터 참고문헌은 APA 7판 형식을 기본으로 사용합니다.
% 한국어 문헌은 langid={korean}, 영어 문헌은 langid={english}를 넣어 주세요.
% 한국어 문헌은 \ktextcite{kor_sample_reference} 또는
% (\kparencite{kor_sample_reference})처럼 인용합니다.
% 영어 문헌은 \textcite{eng_sample_reference} 또는
% (\parencite{eng_sample_reference})처럼 인용합니다.
%
% English:
% Poster references use APA 7th edition formatting by default.
% Add langid={korean} for Korean entries and langid={english} for English entries.
% Cite Korean sources with \ktextcite{kor_sample_reference} or
% (\kparencite{kor_sample_reference}).
% Cite English sources with \textcite{eng_sample_reference} or
% (\parencite{eng_sample_reference}).

@article{kor_sample_reference,
  langid  = {korean},
  author  = {홍길동 and 임꺽정},
  title   = {포스터 인용 예시용 한국어 논문},
  journal = {한국논문작성교육연구},
  year    = {2026},
  volume  = {1},
  number  = {1},
  pages   = {1--10}
}

@article{eng_sample_reference,
  langid  = {english},
  author  = {Author, A. and Researcher, B.},
  title   = {Poster Citation Example Article},
  journal = {Journal Name},
  year    = {2026},
  volume  = {1},
  number  = {1},
  pages   = {1--10},
  doi     = {10.0000/example-doi}
}
